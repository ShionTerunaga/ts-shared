{
  "name": "ts-common",
  "version": "0.0.0",
  "description": "Shared TypeScript utilities with generated type definitions.",
  "homepage": "https://github.com/ShionTerunaga/ts-common#readme",
  "bugs": {
    "url": "https://github.com/ShionTerunaga/ts-common/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShionTerunaga/ts-common.git"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.ja.md",
    "README.md"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "check": "vp check",
    "test": "vp test",
    "prepare": "sh -c 'if [ -d .git ]; then vp exec lefthook install; fi; vp pack'"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "lefthook": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.32.1"
}
