{
  "compilerOptions": {
    "noEmit": true,
    "target": "esnext",
    "module": "preserve",
    "moduleResolution": "bundler",
    "paths": {
      "ts-shared": ["./src/*"]
    },
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src", "scripts", "vite.config.ts", "__test__"]
}
